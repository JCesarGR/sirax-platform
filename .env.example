# ==================== Sirax · Synkdata ====================


                                            Database (PostgreSQL)

DATABASE_URL="postgresql"

                             # ---------- Authentication ----------

JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRE="7d"

                                # ---------- Application ----------
NODE_ENV="production"
PORT=3000
NEXT_PUBLIC_APP_NAME="Sirax"
NEXT_PUBLIC_APP_VENDOR="Synkdata"
NEXT_PUBLIC_APP_URL="https://sirax.example.com"
 ==================== Proveedores de datos reales ====================

# ---------- Nubarium | (CURP/RENAPO, RFC/SAT, historial IMSS, PEPs) ----------

#UBARIUM_USER=""
NUBARIUM_PASSWORD=""

OPENSANCTIONS_API_KEY=""

APIMARKET_API_KEY=""

SERPAPI_API_KEY=""

# ---------- HaveIBeenPwned (brechas de datos del email) ----------

HIBP_API_KEY=""

# ---------- Hunter.io (verificacion/entregabilidad de email) ----------

HUNTER_API_KEY=""

# ---------- Numverify (validacion de telefono) ----------

NUMVERIFY_API_KEY=""
# ---------- Herramientas Locales (OSINT) ----------

# Sherlock: pip install sherlock
SHERLOCK_PATH="sherlock"
# Maigret: pip install maigret
MAIGRET_PATH="maigret"



# ---------- IA (dictamen ejecutivo) — usa cualquier proveedor ----------
# Si dejas todo esto vacío, el reporte usa una plantilla determinística
# (sigue siendo texto real generado desde los datos verificados, solo que
# sin redacción por IA).
#
# AI_PROVIDER fuerza cuál usar: anthropic | openai | google | custom
# Si lo dejas vacío, prueba todos los configurados en ese orden y hace
# fallback automático al siguiente si uno falla.

AI_PROVIDER=""

# Claude (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_MODEL="gpt-4o-mini"
OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=""
# GOOGLE_AI_MODEL="gemini-2.0-flash"

# Cualquier otro proveedor compatible con el formato de OpenAI:

# AI_CUSTOM_BASE_URL="https://api.groq.com/openai/v1"
# AI_CUSTOM_MODEL="llama-3.3-70b-versatile"
# AI_CUSTOM_API_KEY=""
